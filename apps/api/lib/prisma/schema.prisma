generator client {
  provider = "prisma-client-js"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  nickname         String
  profileImage     String?          @map("profile_image")
  createdAt        DateTime         @default(now()) @map("created_at")
  participants     Participant[]
  schedules        ScheduleMember[]
  createdSchedules Schedule[]       @relation("ScheduleCreator")
  availableDates AvailableDate[]

  @@map("users")
}

model Room {
  id            String        @id @default(uuid())
  roomCode      String        @unique @map("room_code")
  category      String
  status        String        @default("waiting")
  linkExpiresAt DateTime      @default(dbgenerated("(now() + '04:00:00'::interval)")) @map("link_expires_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  name          String        @default("")
  imageUrl      String?
  participants  Participant[]
  schedule      Schedule?
  availableDates AvailableDate[]

  @@map("rooms")
}

model Participant {
  id                   String    @id @default(uuid())
  roomCode             String    @map("room_code")
  userId               String    @map("user_id")
  abstractLocation     String    @map("abstract_location")
  lat                  Float
  lng                  Float
  isHost               Boolean   @default(false) @map("is_host")
  leftAt               DateTime? @map("left_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  atmospherePreference String?   @map("atmosphere_preference")
  distanceTolerance    String?   @map("distance_tolerance")
  transports           String[]  @default([])
  room                 Room      @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomCode, userId])
  @@map("participants")
}

model Schedule {
  id           String           @id @default(uuid())
  roomCode     String           @unique @map("room_code")
  title        String
  placeName    String           @map("place_name")
  placeAddress String           @map("place_address")
  lat          Float
  lng          Float
  scheduledAt  DateTime         @map("scheduled_at")
  memo         String?
  createdAt    DateTime         @default(now()) @map("created_at")
  createdBy    String?          @map("created_by")
  members      ScheduleMember[]
  creator      User?            @relation("ScheduleCreator", fields: [createdBy], references: [id])
  room         Room             @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)

  @@map("schedules")
}

model ScheduleMember {
  id         String   @id @default(uuid())
  scheduleId String   @map("schedule_id")
  userId     String   @map("user_id")
  status     String   @default("pending")
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
  @@map("schedule_members")
}

model AvailableDate {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  roomCode  String   @map("room_code")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  room  Room  @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  user  User  @relation(fields: [userId],   references: [id],       onDelete: Cascade)

  @@unique([roomCode, userId, date])
  @@map("available_dates")
}
